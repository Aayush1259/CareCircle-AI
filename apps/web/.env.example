# Frontend-safe environment variables only
# Copy this file to apps/web/.env.local for local frontend development
# Never place secret server-only keys in Vite env files

VITE_API_URL=http://localhost:4000/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key_here
